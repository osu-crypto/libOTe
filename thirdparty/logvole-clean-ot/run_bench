#!/usr/bin/env bash
set -euo pipefail

script_dir="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"

build_dir="${script_dir}/build"
build_type="Release"
seal_dir="${SEAL_DIR:-}"
benchmark_source_dir="${LOGVOLE_BENCHMARK_SOURCE_DIR:-}"
benchmark_filter='^BM_LogVOLE_(2Level|3Level).*'
threads="${LOGVOLE_BENCH_WORKER_THREADS:-4}"
iterations="${LOGVOLE_BENCH_ITERATIONS:-1}"
min_time="0.01"
jobs=""
save_json=""
skip_configure=0
skip_build=0
extra_benchmark_args=()

usage() {
    cat <<'EOF'
Usage: ./run_bench [options] [-- extra-google-benchmark-args]

Configure, build, and run the standalone LogVOLE clean-ot benchmark.

Options:
  --build-dir DIR              Build directory (default: ./build)
  --build-type TYPE            CMake build type (default: Release)
  --seal-dir DIR               SEAL CMake package directory
  --benchmark-source-dir DIR   Local Google Benchmark source directory
  --preset NAME                Benchmark preset: 2level, 3level, 5level, n2p24, n2p25
  --filter REGEX               Override Google Benchmark filter
  --threads N                  Worker threads per party (default: 4)
  --iterations N               Iterations per benchmark case (default: 1)
  --min-time SECONDS           Google Benchmark minimum time (default: 0.01)
  --jobs N                     Build parallelism (default: nproc or 4)
  --save-json PATH             Save Google Benchmark JSON output
  --skip-configure             Reuse an existing CMake configuration
  --skip-build                 Reuse an existing logvole_bench binary
  -h, --help                   Show this help

Examples:
  ./run_bench
  ./run_bench --preset n2p25 --threads 8 --save-json results/n2p25-t8.json
  ./run_bench --seal-dir /path/to/seal/cmake --benchmark-source-dir /path/to/google-benchmark
EOF
}

preset_filter() {
    case "$1" in
        2level) printf '%s\n' '^BM_LogVOLE_2Level(/.*)?$' ;;
        3level) printf '%s\n' '^BM_LogVOLE_3Level(/.*)?$' ;;
        5level) printf '%s\n' '^BM_LogVOLE_5Level_W256(/.*)?$' ;;
        n2p24) printf '%s\n' '^BM_LogVOLE_N2Pow24(/.*)?$' ;;
        n2p25) printf '%s\n' '^BM_LogVOLE_N2Pow25(/.*)?$' ;;
        *)
            printf 'Unknown preset: %s\n' "$1" >&2
            return 2
            ;;
    esac
}

require_value() {
    if [[ $# -lt 2 || -z "$2" ]]; then
        printf 'Missing value for %s\n' "$1" >&2
        exit 2
    fi
}

while [[ $# -gt 0 ]]; do
    case "$1" in
        --build-dir)
            require_value "$@"
            build_dir="$2"
            shift 2
            ;;
        --build-type)
            require_value "$@"
            build_type="$2"
            shift 2
            ;;
        --seal-dir)
            require_value "$@"
            seal_dir="$2"
            shift 2
            ;;
        --benchmark-source-dir)
            require_value "$@"
            benchmark_source_dir="$2"
            shift 2
            ;;
        --preset)
            require_value "$@"
            benchmark_filter="$(preset_filter "$2")"
            shift 2
            ;;
        --filter|--benchmark-filter)
            require_value "$@"
            benchmark_filter="$2"
            shift 2
            ;;
        --threads)
            require_value "$@"
            threads="$2"
            shift 2
            ;;
        --iterations)
            require_value "$@"
            iterations="$2"
            shift 2
            ;;
        --min-time)
            require_value "$@"
            min_time="$2"
            shift 2
            ;;
        --jobs|-j)
            require_value "$@"
            jobs="$2"
            shift 2
            ;;
        --save-json)
            require_value "$@"
            save_json="$2"
            shift 2
            ;;
        --skip-configure)
            skip_configure=1
            shift
            ;;
        --skip-build)
            skip_build=1
            shift
            ;;
        -h|--help)
            usage
            exit 0
            ;;
        --)
            shift
            extra_benchmark_args+=("$@")
            break
            ;;
        *)
            printf 'Unknown argument: %s\n\n' "$1" >&2
            usage >&2
            exit 2
            ;;
    esac
done

if [[ "$build_dir" != /* ]]; then
    build_dir="${script_dir}/${build_dir}"
fi

if [[ -z "$seal_dir" ]]; then
    for candidate in \
        "${script_dir}/../build_loglabel_bench/cmake" \
        "${script_dir}/../build_loglabel_tests/cmake" \
        "${script_dir}/../build/cmake"
    do
        if [[ -f "${candidate}/SEALConfig.cmake" ]]; then
            seal_dir="$(cd -- "$candidate" && pwd)"
            break
        fi
    done
fi

if [[ -z "$benchmark_source_dir" ]]; then
    for candidate in \
        "${script_dir}/thirdparty/benchmark" \
        "${script_dir}/../thirdparty/benchmark" \
        "${script_dir}/../build_loglabel_bench/thirdparty/benchmark-src" \
        "${HOME:-}/git/llvm-project/third-party/benchmark" \
        "${HOME:-}/git/llvm-pass/third-party/benchmark" \
        "${HOME:-}/git/LLVM-for-MPC/LLVM/llvm/utils/benchmark"
    do
        if [[ -f "${candidate}/CMakeLists.txt" && -f "${candidate}/include/benchmark/benchmark.h" ]]; then
            benchmark_source_dir="$(cd -- "$candidate" && pwd)"
            break
        fi
    done
fi

if [[ -z "$jobs" ]]; then
    if command -v nproc >/dev/null 2>&1; then
        jobs="$(nproc)"
    else
        jobs="4"
    fi
fi

cmake_args=(
    cmake
    -S "$script_dir"
    -B "$build_dir"
    "-DCMAKE_BUILD_TYPE=${build_type}"
    -DLOGVOLE_BUILD_TESTS=OFF
    -DLOGVOLE_BUILD_BENCH=ON
    -DLOGVOLE_BUILD_EXAMPLES=OFF
)

if [[ -n "$seal_dir" ]]; then
    cmake_args+=("-DSEAL_DIR=${seal_dir}")
fi

if [[ -n "$benchmark_source_dir" ]]; then
    cmake_args+=("-DLOGVOLE_BENCHMARK_SOURCE_DIR=${benchmark_source_dir}")
fi

if [[ "$skip_configure" -eq 0 ]]; then
    printf 'Configuring clean-ot benchmark build in %s\n' "$build_dir"
    "${cmake_args[@]}"
fi

if [[ "$skip_build" -eq 0 ]]; then
    printf 'Building logvole_bench with %s jobs\n' "$jobs"
    cmake --build "$build_dir" --target logvole_bench --parallel "$jobs"
fi

bench_binary="${build_dir}/bin/logvole_bench"
if [[ ! -x "$bench_binary" ]]; then
    printf 'Benchmark binary not found or not executable: %s\n' "$bench_binary" >&2
    exit 1
fi

benchmark_args=(
    "$bench_binary"
    "--benchmark_filter=${benchmark_filter}"
    "--benchmark_min_time=${min_time}"
)

if [[ -n "$save_json" ]]; then
    save_dir="$(dirname -- "$save_json")"
    if [[ "$save_dir" != "." ]]; then
        mkdir -p "$save_dir"
    fi
    benchmark_args+=(
        --benchmark_format=json
        "--benchmark_out=${save_json}"
        --benchmark_out_format=json
    )
fi

benchmark_args+=("${extra_benchmark_args[@]}")

printf 'Running clean-ot benchmark: filter=%s threads=%s iterations=%s\n' "$benchmark_filter" "$threads" "$iterations"
LOGVOLE_BENCH_WORKER_THREADS="$threads" \
LOGVOLE_BENCH_SENDER_THREADS="$threads" \
LOGVOLE_BENCH_RECEIVER_THREADS="$threads" \
LOGVOLE_BENCH_ITERATIONS="$iterations" \
    "${benchmark_args[@]}"
